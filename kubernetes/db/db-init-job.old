apiVersion: batch/v1
kind: Job
metadata:
  creationTimestamp: null
  name: db-init
  namespace: dev
spec:
  template:
    metadata:
      creationTimestamp: null
    spec:
      containers:
      - image: mysql:8.0
        name: db-init
        command: 
        - sh
        - -c
        - |
          mysql -h mysql-service.dev.svc.cluster.local \
                -u ecomuser \
                -pecompassword \
                ecomdb < /scripts/db-load-script.sql
        volumeMounts:
        - name: db-init-script
          mountPath: /scripts
      volumes:
      - name: db-init-script
        configMap:
          name: db-init-script
      restartPolicy: OnFailure
status: {}
